# --- Database ---
# App connection. On Neon/Supabase use the pooled connection string here.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ranklens?schema=public"
# Migration connection (prisma migrate). On Neon use the DIRECT endpoint
# (hostname without "-pooler"); locally just repeat DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ranklens?schema=public"

# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_TRUST_HOST="true"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Google integrations (Search Console + GA4 OAuth) ---
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${NEXT_PUBLIC_APP_URL}/api/v1/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Google PageSpeed Insights ---
# API key from Google Cloud Console (PageSpeed Insights API enabled)
PAGESPEED_API_KEY=""

# --- SERP provider (keyword rank tracking) ---
# Supported: "serpapi" (https://serpapi.com) or "mock" (demo data, no key needed)
SERP_PROVIDER="mock"
SERPAPI_KEY=""
# How deep to look for your domain (10-100, rounded to pages of 10).
# Each page of 10 costs one SerpAPI credit; lookups stop early when found.
SERP_DEPTH="20"

# --- Backlink provider ---
# Backlink discovery requires a paid data source (no free API exists).
# Options:
#   unset   -> backlink tracking is off; the UI shows a "not connected" state
#   demo    -> deterministic sample data for previewing the UI (clearly fake)
#   dataforseo -> real backlinks via https://dataforseo.com (pay-as-you-go)
BACKLINK_PROVIDER=""
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# --- Email (SMTP) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="RankLens <no-reply@ranklens.local>"

# --- Scheduled scans (serverless) ---
# Shared secret for POST /api/v1/cron, used by the Netlify scheduled function
# (or any external scheduler) to trigger due scans. Generate a random string.
CRON_SECRET=""

# --- Storage (legacy) ---
# Reports are stored in the database; this dir is only read as a fallback for
# reports generated by older versions.
REPORT_STORAGE_DIR="./storage/reports"
